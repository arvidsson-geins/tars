# Artifacts and build
data/
.env
.env.*
__pycache__/
*.pyc
.venv/
*.egg-info/
dist/
.ruff_cache/
node_modules/
.claude/
.mint/

# Deployment config — generated by setup.py, keep private
config/config.yaml
config/config.*.yaml
!config/config.yaml.example
config/agents.yaml
config/agents.*.yaml
!config/agents.yaml.example
config/team.json
!config/team.json.example
config/mcp.yaml

# Secrets — never commit
config/secrets.enc
config/secrets.salt
*.key
*.pem

# Agent workspaces — deployment-specific, never commit.
# Everything under agents/ is ignored except the rescue example.
agents/*
!agents/rescue
!agents/rescue/CLAUDE.md.example
.mcp.json

# Compression originals — generated by compress-context.sh
*.original.md
*.original.yaml

# Runtime security baselines — deployment-specific
.security/
