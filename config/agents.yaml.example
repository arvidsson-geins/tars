agents:
  rescue:
    display_name: "Rescue Bot"
    description: "Privileged system agent — full project access for dev/ops"
    project_dir: ./agents/rescue
    privileged: true
    llm:
      provider: claude_code
      model: sonnet
      # mcp_config: /path/to/mcp.yaml  # Optional: MCP server config for this agent
    tools: all
    skills: all
    # Block Claude Code's built-in file/shell tools. The agent still has full
    # MCP tool access (memory, web, integrations, browse_url, etc.) but cannot
    # edit source code, run arbitrary shell commands, or write files directly.
    # Recommended default for coordinator- and assistant-tier agents.
    disallow_builtins:
      - Edit
      - Write
      - Bash
      - MultiEdit
    # compression:             # per-agent override (inherits from config.yaml defaults)
    #   enabled: true
    #   level: lite
    routing:
      discord:
        account: main         # bot account (namespace — each bot routes independently)
        channels: []          # empty = all channels (wildcard)
        # categories: []      # Discord category IDs — all channels in category match
        # guilds: []          # filter: restrict to specific servers (applies on top of scope)
        mentions: true        # filter: only respond when @mentioned
        # Scope priority: specific channel > category > wildcard
        # Filters (account, guilds, mentions) apply independently of scope

  # Example: assistant-tier agent with a restricted tool whitelist
  # assistant:
  #   display_name: "Helper"
